# Supabase
# Dashboard > Project Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://ystxvlibeqdrlnsriidh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_9kuOsgadoPXGD3AiAWxGhA_mq9Ep4G9

# 네이버 로그인 UI — 기본 노출. 끄려면 명시적으로 false:
# NEXT_PUBLIC_NAVER_LOGIN_ENABLED=false
# NAVER_LOGIN_ENABLED=false

# 네이버 로그인 (앱에서 OAuth 직접 처리) — 네이버 개발자센터 콜백 URL:
#   http://localhost:<포트>/auth/callback/naver  (로컬 포트·프로덕션 도메인 각각 등록)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# 네이버 콜백에서 Supabase Auth 사용자 생성/로그인에 필요 (Dashboard > API > service_role, 서버 전용)
SUPABASE_SERVICE_ROLE_KEY=

# AI — 원고 분석은 Claude만 사용 (플랫폼은 프롬프트만 분기)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
# (선택) 레지스트리·향후 확장용 — 분석 프로필은 전부 Anthropic
# https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# NAT/코인: 마이그레이션 `20260410220000_coin_logs_audit_ledger.sql` 등 적용 후
# users.coin_balance + coin_logs 원장, consume_nat / credit_nat RPC
# GET /api/admin/coin-ledger-stats (일·월별 집계) — 아래 비밀값 필요:
# COIN_ADMIN_SECRET=

# 비동기 이 화 분석: supabase-migration-analysis-jobs.sql 또는 supabase db push
# 서버 간 /api/analyze/process 호출용 공유 비밀 (openssl rand -hex 32)
ANALYZE_PROCESS_SECRET=
# (선택) 통합 분석 실행 허용 시간(초). 미설정 시 600. Vercel 플랜 maxDuration 상한에 맞게 조정.
# ANALYZE_PROCESS_MAX_DURATION_SEC=600
# 공개 사이트 URL — Vercel·프로덕션 권장.
# 로컬 개발: 비워 두거나 http://localhost:<포트> (서버 self-call·내부 URL용). next dev 가 3003 등이면 포트 맞출 것.
#
# Google 로그인이 프로덕션으로 튀면 → Supabase Dashboard > Authentication > URL Configuration:
#   Redirect URLs 에 **브라우저 주소창과 같은 origin** (포트 포함) 을 등록. 예: dev 가 3003 이면
#   - http://localhost:3003/auth/callback
#   - http://127.0.0.1:3003/auth/callback   (127.0.0.1 로 여는 경우)
#   또는 와일드카드: http://localhost:3003/** , http://127.0.0.1:3003/**
# (3000 만 등록해 두고 실제로는 3003 으로 띄우면 redirect_to 가 거부되어 Site URL(라이브)로 감)
# Site URL 이 프로덕션만 있어도 redirect_to 가 허용 목록에 없으면 Site URL 로 돌아갈 수 있음.
NEXT_PUBLIC_SITE_URL=

# POST /api/analyze 레이트 리밋(분당 3회/유저) — https://console.upstash.com Redis 생성 후 REST 탭
# 프로덕션(Vercel): 두 값 모두 설정 시에만 제한 활성화. 미설정 시 콘솔에 경고만 출력(무제한).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry — https://sentry.io (프로젝트 Settings → Client Keys (DSN))
SENTRY_DSN=
# (선택) 소스맵 업로드·릴리즈: Sentry → Settings → Auth Tokens
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# 에러 시 Slack Incoming Webhook (서버·엣지에서만 사용, 클라이언트에 노출하지 마세요)
SLACK_WEBHOOK_URL=

# Solapi (CoolSMS) — 휴대폰 인증 SMS. npm 패키지 `solapi`, 대시보드 https://solapi.com
# https://docs.coolsms.co.kr
# 로컬 테스트: COOLSMS_MOCK=1 이면 실제 발송 없이 콘솔에 인증번호 출력
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
COOLSMS_FROM=
COOLSMS_MOCK=
# OTP 코드 HMAC용(32자 이상 권장). 서버 전용, 절대 클라이언트에 노출 금지
SMS_OTP_SECRET=

# 문의 메일 (플로팅 버튼·이용약관 페이지). 미설정 시 기본 agent@novelagent.kr
# NEXT_PUBLIC_CONTACT_EMAIL=agent@novelagent.kr

# --- 트렌드 자동화 (`npm run trends:automate`) ---
# Serper https://serper.dev — Google 검색 API (지난 24시간 tbs=qdr:d)
SERPER_API_KEY=
# (선택) 랭킹 페이지 URL — DOM 변경 시 덮어쓰기
# MUNPIA_RANKING_URL=https://m.munpia.com/genres/best/novels
# MUNPIA_TODAY_BEST_URL=https://www.munpia.com/page/j/view/w/best/today?displayType=GRID
# KAKAO_RANKING_URL=https://page.kakao.com/menu/10011/screen/94
# NAVER_SERIES_RANKING_URL=https://series.naver.com/novel/top100List.series?categoryCode=ALL&rankingTypeCode=DAILY
#
# 문피아 심층 자동 크론 (`npm run trends:automate:cron`, EC2 `ec2_munpia_random_start.sh`). 1/true 일 때만 등록·실행. 미설정·0 = 비활성(데일리 크론만 유지)
# MUNPIA_READER_CRON_ENABLED=1
#
# 문피아 독자 패턴 본문 수집 (`npm run trends:munpia-scrape`)
# 자동 선정: MUNPIA_READER_WORKS_JSON 을 비우면 모바일 무료 베스트(기본 m.munpia.com/genres/best/novels) 1~20·급상승 우선, Chroma/DB에 이미 munpia_novel_key 있으면 스킵
# MUNPIA_BEST_MOBILE_URL=https://m.munpia.com/genres/best/novels
# MUNPIA_READER_MAX_WORKS_PER_RUN=10
# 자동 모드에서만: 특정 순위만 (쉼표). 드라이런과 함께 쓰면 해당 순위 후보만 미리보기(중복 스킵 무시)
# MUNPIA_READER_FILTER_RANKS=1
# 이미 수집(인제스트)된 작품도 강제로 다시 실행(저장/인제스트까지). 디버깅용, 남용 금지.
# MUNPIA_READER_IGNORE_DUPLICATE=1
# 회차 수집 상한(랜덤 min~max). 코드 기본 15~15(연독률·지표 분석용). 짧게 테스트할 때만 예: 3,5
# MUNPIA_READER_EPISODES_MIN=15
# MUNPIA_READER_EPISODES_MAX=15
# Claude 요약에 넣는 뷰어 원문 최대 글자수(기본 96000). 15화·장문 작품은 150000~250000 등으로 상향
# MUNPIA_READER_CLAUDE_CORPUS_MAX_CHARS=200000
# 작품 간 대기(ms) — 서버 부하 완화
# MUNPIA_READER_BETWEEN_WORKS_MS_MIN=5500
# MUNPIA_READER_BETWEEN_WORKS_MS_MAX=11000
# 회차 진입 후 본문 수집 전 대기(ms) — 3~5초 권장
# MUNPIA_READER_EPISODE_WAIT_MS_MIN=3000
# MUNPIA_READER_EPISODE_WAIT_MS_MAX=5000
# 회차 간 대기(ms) — 3~5초 권장
# MUNPIA_READER_BETWEEN_EPISODES_MS_MIN=3000
# MUNPIA_READER_BETWEEN_EPISODES_MS_MAX=5000
# 스크롤은 천천히, 단 전체 스크롤 시간은 최대 10초(기본) 제한
# MUNPIA_READER_SCROLL_MAX_MS=10000
# 차단/과부하(403/429/5xx) 감지 시 백오프 후 종료(ms). 기본 20분
# MUNPIA_READER_BACKOFF_MS=1200000
# (선택) 문피아 크론(04:10 실행) 시작을 04:10~06:00 사이 랜덤 지연. 최대값(ms) 제한 (기본 110분)
# MUNPIA_CRON_RANDOM_DELAY_MAX_MS=6600000

# 쿠키 만료 감지 알림(슬랙/카톡 등) — Slack Incoming Webhook URL 권장
# COMMANDER_ALERT_WEBHOOK_URL=...
# 수동 작품 지정: 아래 JSON 문자열 또는 파일 경로(파일이 있으면 JSON 내용이 우선)
# MUNPIA_READER_WORKS_PATH=./scripts/munpia-reader-works.example.json
# MUNPIA_READER_WORKS_JSON=[{"title":"작품명","novelKey":"553210","detailUrl":"https://m.munpia.com/novel/detail/553210"}]
# urls 생략 시 목차에서 회차 자동 선정. CLI: npm run trends:munpia-scrape -- --munpia-works-file=./scripts/munpia-reader-works.example.json
# 목차 회차 선정: /page/1~N 만 조회 (기본 3). 각 페이지에서 "최하단" 회차부터 최대 5개를 선택.
# MUNPIA_READER_TOC_MAX_PAGE=3
# HEADLESS=0 npm run trends:munpia-scrape:dry
# Linux(EC2)에서는 기본이 풀 Chromium headless — 아래는 특수 경우만
# PLAYWRIGHT_USE_HEADLESS_SHELL=1   # 대신 chromium-headless-shell 쓰기(별도 install)
# PLAYWRIGHT_USE_FULL_CHROMIUM=1    # macOS/Windows에서도 풀 Chromium 강제
# 시드니 Chroma — 미설정 시 scripts/automate_trends.ts 기본 54.252.238.168:8000
# CHROMA_SERVER_HOST=54.252.238.168
# CHROMA_SERVER_PORT=8000

# --- 무료 회차 요약 인제스트 (`npm run trends:ingest-free-episodes`) ---
# 로그인 세션: Playwright `storageState` JSON 또는 쿠키 배열 → 프로젝트 루트 data/cookies.json 권장
# PLAYWRIGHT_COOKIES_PATH=./data/cookies.json
# 문피아 세션 자동 저장 (`npm run cookies:munpia`) — 아래만 설정, 비밀번호는 절대 커밋하지 마세요
# MUNPIA_LOGIN_ID=
# MUNPIA_LOGIN_PASSWORD=
# (선택) 기본은 nssl 통합 로그인. 바꿀 때만 지정
# MUNPIA_LOGIN_PAGE_URL=https://nssl.munpia.com/login?redirectUrl=https%3A%2F%2Fwww.munpia.com%2F
# 브라우저 표시(캡차 등): HEADLESS=0 npm run cookies:munpia
# 1~5화 등 뷰어 URL을 쉼표로 (순서대로)
# FREE_EPISODE_MUNPIA_URLS=
# FREE_EPISODE_KAKAO_URLS=
# FREE_EPISODE_MUNPIA_TITLE=샘플작 문피아
# FREE_EPISODE_KAKAO_TITLE=샘플작 카카오
# 회차 간 랜덤 대기(ms). 기본 3000~5000 (page.waitForTimeout 대신 setTimeout)
# FREE_EPISODE_DELAY_MS_MIN=3000
# FREE_EPISODE_DELAY_MS_MAX=5000
# 본문 셀렉터 (쉼표 구분, 사이트 개편 시)
# FREE_EPISODE_CONTENT_SELECTORS=article,#content,main

# --- Chroma RAG (웹소설 트렌드) — 로컬 전용 권장 ---
# 터미널 1: npm run chroma:run  → 터미널 2: npm run trends:ingest → next dev
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
# CHROMA_SSL=false
# 설정 시 검색 API는 Bearer 만 허용(로그인 불필요). 미설정 시 로그인 세션 필요.
# TRENDS_RAG_API_SECRET=
# 분석 에이전트가 RAG를 **HTTP로** `/api/rag/trends/search` 에 먼저 치게 하려면(선택):
# `TRENDS_RAG_API_SECRET` + 아래 베이스 URL(끝 슬래시 없음). 없으면 Chroma 직접 호출.
# TRENDS_RAG_SEARCH_BASE_URL=http://localhost:3000
