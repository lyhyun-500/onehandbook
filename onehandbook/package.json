    "md5": "^2.3.0",
    "next": "16.1.7",
    "node-cron": "^4.2.1",
    "playwright": "^1.59.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "solapi": "^5.5.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/md5": "^2.3.6",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
