# Vercel → Project → Settings → Environment Variables
# Production(및 필요 시 Preview)에 동일하게 추가하세요.
# 값은 로컬 onehandbook/.env.local 을 참고해 채우면 됩니다. (비밀은 저장소에 커밋하지 마세요)

# --- 필수: 로그인·DB ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- 강력 권장: OAuth·내부 URL (배포 후 https://xxx.vercel.app 또는 커스텀 도메인) ---
NEXT_PUBLIC_SITE_URL=

# --- 필수에 가깝음: 비동기 분석 /api/analyze/process (openssl rand -hex 32) ---
ANALYZE_PROCESS_SECRET=

# --- AI 분석 (Claude) ---
ANTHROPIC_API_KEY=

# --- (선택) 다른 프로바이더 ---
GOOGLE_GENERATIVE_AI_API_KEY=

# --- (선택) 프로덕션 레이트 리밋 — 둘 다 있을 때만 적용 ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- (선택) Sentry — next.config가 SENTRY_DSN으로 클라이언트에 전달 ---
SENTRY_DSN=
# 소스맵 업로드·릴리즈용 (빌드 시만)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# --- (선택) 에러 알림 Slack ---
SLACK_WEBHOOK_URL=

# --- (선택) 휴대폰 인증 SMS (Solapi) ---
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
COOLSMS_FROM=
# COOLSMS_MOCK=
SMS_OTP_SECRET=

# --- (선택) 네이버 로그인 — 비우면 버튼은 있어도 /api/auth/naver/start 가 실패 ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 회원 탈퇴 등 서버 관리 작업 (절대 클라이언트에 노출 금지) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- (선택) 문의 메일 오버라이드 — 비우면 코드 기본 agent@novelagent.kr ---
# NEXT_PUBLIC_CONTACT_EMAIL=
